{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sistemassi",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "build/web"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "env": {
    "staging": {
      "name": "sistemassi-staging"
    }
  }
}
